<Window x:Class="SytexLCore.MiniMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        Height="52" Width="310"
        WindowStartupLocation="Manual" Left="20" Top="20"
        Title="SYTEX Mini Menu">

    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush"    Color="#EE0E1118"/>
        <SolidColorBrush x:Key="BorderCyan" Color="#00F0FF"/>
        <SolidColorBrush x:Key="AccentPink" Color="#FF007F"/>

        <!-- Mini İşlevsel Buton Stili (ikon + metin) -->
        <Style x:Key="MiniBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B58B9D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="#00F0FF" BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF007F"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Kırmızı Kapat Butonu -->
        <Style x:Key="CloseMiniBtnStyle" TargetType="Button" BasedOn="{StaticResource MiniBtn}">
            <Setter Property="Foreground" Value="#FF0055"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource BorderCyan}"
            BorderThickness="2"
            MouseDown="Border_MouseDown">
        <Border.Effect>
            <DropShadowEffect Color="#00F0FF" BlurRadius="14" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>

        <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- Logo / Drag -->
                <ColumnDefinition Width="*"/>    <!-- Butonlar -->
                <ColumnDefinition Width="Auto"/> <!-- Sistem Butonları -->
            </Grid.ColumnDefinitions>

            <!-- Sol: Logo + Drag Handle -->
            <Border Grid.Column="0" Background="#1A1523" BorderBrush="#00F0FF" BorderThickness="0,0,2,0"
                    Padding="8,0" Cursor="SizeAll" MouseDown="Border_MouseDown">
                <TextBlock Text="SX" Foreground="#00F0FF" FontFamily="Consolas" FontSize="13"
                           FontWeight="Bold" VerticalAlignment="Center"/>
            </Border>

            <!-- Orta: İşlevsel Butonlar -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Stretch" HorizontalAlignment="Left">

                <!-- Otomatik Çeviri Aç/Kapa (Durum Göstergesi ile) -->
                <Button x:Name="AutoBtn" Click="AutoBtn_Click" Style="{StaticResource MiniBtn}"
                        ToolTip="Otomatik Çeviriyi Aç / Kapa">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="StatusDot" Width="8" Height="8" CornerRadius="4"
                                Background="#FF0055" Margin="0,0,6,0" VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF0055" BlurRadius="6" ShadowDepth="0"/>
                            </Border.Effect>
                        </Border>
                        <TextBlock Text="OTO" FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                   Foreground="#00F0FF" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Dikey Ayraç -->
                <Rectangle Width="1" Height="22" Fill="#2A2035" VerticalAlignment="Center" Margin="2,0"/>

                <!-- Manuel Seçim (Kırpıcı) -->
                <Button Click="ManualBtn_Click" Style="{StaticResource MiniBtn}"
                        ToolTip="Manuel Bölge Seç (F9)">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⛶" FontSize="13" Foreground="#00F0FF" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="SEÇ" FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                   Foreground="#00F0FF" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Dikey Ayraç -->
                <Rectangle Width="1" Height="22" Fill="#2A2035" VerticalAlignment="Center" Margin="2,0"/>

                <!-- Ayarlar -->
                <Button Click="SettingsBtn_Click" Style="{StaticResource MiniBtn}"
                        ToolTip="Ayarlar ve Ana Panel">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚙" FontSize="13" Foreground="#B58B9D" Margin="0,0,5,0" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(RotateTransform.Angle)" To="360" Duration="0:0:0.8" RepeatBehavior="Forever"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="0" CenterX="8" CenterY="8"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock Text="AYAR" FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                   Foreground="#B58B9D" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Sağ: Sistem Butonları -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch"
                        HorizontalAlignment="Right">
                <Rectangle Width="1" Height="22" Fill="#2A2035" VerticalAlignment="Center" Margin="2,0"/>

                <!-- Tray'e Küçült -->
                <Button Click="TrayBtn_Click" Style="{StaticResource MiniBtn}"
                        ToolTip="Arka Plana Al" Width="32" Padding="0">
                    <TextBlock Text="🗕" FontSize="11" Foreground="#B58B9D" VerticalAlignment="Center"/>
                </Button>

                <!-- Kapat -->
                <Button Click="CloseBtn_Click" Style="{StaticResource MiniBtn}"
                        ToolTip="Tamamen Kapat" Width="32" Padding="0">
                    <TextBlock Text="✕" FontSize="12" Foreground="#FF0055" FontWeight="Bold" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
