<Window x:Class="SytexLCore.CropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        WindowState="Maximized" Cursor="Cross"
        Title="📸 Çeviri Alanı Seç"
        Loaded="Window_Loaded">

    <Grid x:Name="RootGrid" Background="#66000000" MouseDown="RootGrid_MouseDown" MouseMove="RootGrid_MouseMove" MouseUp="RootGrid_MouseUp">
        <!-- Seçim kutusu canvası -->
        <Canvas x:Name="SelectionCanvas">
            <!-- Seçilen alanı gösteren neon çerçeveli dikdörtgen -->
            <Rectangle x:Name="SelectionBox"
                       Stroke="#FF0055" StrokeThickness="2"
                       Fill="#22FF0055"
                       Visibility="Collapsed"/>
        </Canvas>

        <!-- Bilgi yazısı -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,40,0,0" Background="#EE0A0D17" BorderBrush="#00F5FF" BorderThickness="1" CornerRadius="4" Padding="16,8">
            <Border.Effect>
                <DropShadowEffect Color="#00F5FF" BlurRadius="8" ShadowDepth="0"/>
            </Border.Effect>
            <TextBlock Text="📸 Çeviri yapılacak alanı mouse ile sürükleyerek seçin. İptal etmek için Kısayol (F9) tuşuna basın."
                       Foreground="#FFFFFF" FontFamily="Segoe UI Semibold" FontSize="12"/>
        </Border>
    </Grid>
</Window>
