<Application x:Class="SytexLCore.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <!-- Global renkler -->
        <SolidColorBrush x:Key="BgBrush"      Color="#080D14"/>
        <SolidColorBrush x:Key="PanelBrush"   Color="#0D1828"/>
        <SolidColorBrush x:Key="BorderBrush"  Color="#1A2D42"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="#00D4FF"/>
        <SolidColorBrush x:Key="PurpleBrush"  Color="#7C3AED"/>
        <SolidColorBrush x:Key="TextBrush"    Color="#E2E8F0"/>
        <SolidColorBrush x:Key="MutedBrush"   Color="#64748B"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
        <SolidColorBrush x:Key="WarnBrush"    Color="#F59E0B"/>

        <!-- Global font -->
        <FontFamily x:Key="MainFont">Segoe UI</FontFamily>

        <!-- Buton stili -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"   Value="#7C3AED"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="16,10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6D28D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Radio buton stili -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground"  Value="#E2E8F0"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Margin"      Value="0,4"/>
            <Setter Property="Cursor"      Value="Hand"/>
        </Style>
    </Application.Resources>
</Application>
